    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
