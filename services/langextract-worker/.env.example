# Gemini API key for LangExtract. Use "pending-gemini-setup" to run the service
# in mock mode where all extraction calls return deterministic fake payloads.
GEMINI_API_KEY=pending-gemini-setup

# Port the FastAPI service binds to. Railway injects PORT automatically.
PORT=8000

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# Default model id. Gemini 2.5 Flash is cheap + fast for structured extraction.
LANGEXTRACT_MODEL=gemini-2.5-flash
