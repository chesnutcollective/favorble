# Supabase Local Development
# Run `supabase start` to get these values
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Direct database connection (for Drizzle migrations)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# PostHog Analytics (optional - app works without these)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=

# Encryption key for SSN and other sensitive data
ENCRYPTION_KEY=

# Case Status Integration (optional)
CASE_STATUS_API_KEY=
CASE_STATUS_API_URL=https://api.casestatus.com

# Microsoft Graph API for Outlook integration (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ─── Search ────────────────────────────────────────────────────────
# Global search (Cmd+K palette). See docs/search/ for the full guide.

# Embedding provider used by /api/search/v2 and scripts/embedding-worker.ts
# One of: azure | openai | bge | stub (default stub = semantic disabled)
SEARCH_EMBEDDING_PROVIDER=stub
# Must match the search_documents.embedding column type in migration 0006.
SEARCH_EMBEDDING_DIM=1536
# Rows per embedding-worker iteration.
SEARCH_EMBEDDING_BATCH_SIZE=32
# Truncate any body content longer than this before embedding.
SEARCH_EMBEDDING_MAX_CHARS=8000
# Sleep between worker poll iterations (LOOP=1 mode only).
SEARCH_EMBEDDING_LOOP_INTERVAL_MS=5000

# Azure OpenAI (the BAA-compliant default for PHI workloads).
# Required when SEARCH_EMBEDDING_PROVIDER=azure.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# OpenAI direct (Enterprise BAA only — Azure is the recommended path).
# Required when SEARCH_EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Self-hosted BGE-m3 (or any HF Text-Embeddings-Inference-compatible endpoint).
# Required when SEARCH_EMBEDDING_PROVIDER=bge.
BGE_EMBEDDING_URL=

# ─── Railway S3-compatible bucket (for Chronicle-imported PDFs) ───
# See lib/storage/railway-bucket.ts
RAILWAY_BUCKET_ENDPOINT=https://t3.storageapi.dev
RAILWAY_BUCKET_REGION=auto
RAILWAY_BUCKET_NAME=
RAILWAY_BUCKET_ACCESS_KEY_ID=
RAILWAY_BUCKET_SECRET_ACCESS_KEY=
